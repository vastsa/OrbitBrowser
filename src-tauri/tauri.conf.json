{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Orbit Browser",
  "version": "0.3.2",
  "identifier": "com.orbit.browser",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Orbit Browser",
        "width": 1320,
        "height": 860,
        "minWidth": 1280,
        "minHeight": 720,
        "label": "main",
        "center": true,
        "resizable": true,
        "maximizable": true,
        "minimizable": true,
        "closable": true,
        "visible": true,
        "backgroundColor": "#F7F9FC",
        "titleBarStyle": "Overlay",
        "trafficLightPosition": {
          "x": 18,
          "y": 18
        },
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "Orbit Browser contributors",
    "category": "DeveloperTool",
    "shortDescription": "Local browser runtime orchestrator",
    "longDescription": "Orbit Browser manages isolated Chrome profiles, proxies, automation tasks, and local execution history."
  }
}
